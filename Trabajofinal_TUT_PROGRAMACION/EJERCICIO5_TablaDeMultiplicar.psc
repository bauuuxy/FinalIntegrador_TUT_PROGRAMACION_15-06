Algoritmo TablaDeMultiplicar
		
		Definir n, i Como Entero
		Escribir "=================================="
		Escribir "Ingrese un numero para ver su tabla de multiplicar:"
		Escribir "=================================="
		Leer n
		
		Para i <- 1 Hasta 20
			Escribir n, " x ", i, " = ", n * i
		FinPara
		
FinProceso